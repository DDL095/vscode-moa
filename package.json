{
  "name": "moa-bridge",
  "displayName": "MoA Bridge - Mixture of Agents for Copilot",
  "description": "@moa chat participant — Mixture-of-Agents multi-perspective analysis via PowerShell MoA scripts",
  "version": "0.1.0",
  "publisher": "moa-bridge",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "chatParticipants": [
      {
        "id": "moa-bridge.moa",
        "name": "moa",
        "fullName": "MoA Bridge",
        "description": "Trigger Mixture-of-Agents multi-perspective analysis",
        "isSticky": true,
        "commands": [
          {
            "name": "preset",
            "description": "Switch preset (default/fast/academic/custom)"
          },
          {
            "name": "help",
            "description": "Show MoA Bridge usage"
          }
        ],
        "disambiguation": [
          {
            "category": "moa",
            "description": "Multi-perspective analysis with multiple LLM advisors",
            "examples": [
              "多视角分析",
              "多模型对比",
              "moa 规划",
              "mixture of agents",
              "@moa 分析单细胞轨迹"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "MoA Bridge",
      "properties": {
        "moa.preferredModels": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Preferred model name substrings (e.g. [\"GLM-5.2\", \"DeepSeek-V4-Pro\", \"MiniMax-M3\"]). When set, only models whose name contains one of these substrings are considered. Use this to skip placeholder/expired models.",
          "order": 1
        },
        "moa.defaultPreset": {
          "type": "string",
          "default": "default",
          "enum": ["default", "fast", "academic", "custom"],
          "description": "Default preset to use when no preset is specified in the prompt.",
          "order": 2
        },
        "moa.timeoutSec": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "description": "Per-call timeout in seconds.",
          "order": 3
        },
        "moa.parallelRefs": {
          "type": "boolean",
          "default": false,
          "description": "Fan out reference advisors in parallel (may cause cascading 4xx/5xx when models have expired subscriptions).",
          "order": 4
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}